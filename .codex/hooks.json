{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; sh \"$ROOT/.codex/hooks/run-node.sh\" \"$ROOT/.codex/hooks/descriptive-name.cjs\""
          }
        ]
      },
      {
        "matcher": "Bash|apply_patch|Edit|Write|mcp__filesystem__.*",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; sh \"$ROOT/.codex/hooks/run-node.sh\" \"$ROOT/.codex/hooks/scout-block.cjs\""
          },
          {
            "type": "command",
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; sh \"$ROOT/.codex/hooks/run-node.sh\" \"$ROOT/.codex/hooks/privacy-block.cjs\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; sh \"$ROOT/.codex/hooks/run-node.sh\" \"$ROOT/.codex/hooks/session-state.cjs\""
          },
          {
            "type": "command",
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; sh \"$ROOT/.codex/hooks/run-node.sh\" \"$ROOT/.codex/hooks/post-edit-simplify-reminder.cjs\""
          }
        ]
      },
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; sh \"$ROOT/.codex/hooks/run-node.sh\" \"$ROOT/.codex/hooks/post-write-plan-check.mjs\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; sh \"$ROOT/.codex/hooks/run-node.sh\" \"$ROOT/.codex/hooks/post-commit-lint.mjs\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; sh \"$ROOT/.codex/hooks/run-node.sh\" \"$ROOT/.codex/hooks/session-state.cjs\""
          },
          {
            "type": "command",
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; sh \"$ROOT/.codex/hooks/run-node.sh\" \"$ROOT/.codex/hooks/stop-validator-sweep.cjs\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; sh \"$ROOT/.codex/hooks/run-node.sh\" \"$ROOT/.codex/hooks/session-state.cjs\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; sh \"$ROOT/.codex/hooks/run-node.sh\" \"$ROOT/.codex/hooks/session-init.cjs\""
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; sh \"$ROOT/.codex/hooks/run-node.sh\" \"$ROOT/.codex/hooks/subagent-init.cjs\""
          }
        ]
      }
    ]
  }
}
